{
  "name": "@attestto-com/cr-vc-sdk",
  "version": "0.1.0",
  "description": "SDK for issuing and verifying Verifiable Credentials in the Costa Rica SSI driving ecosystem",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "build:types": "tsc",
    "prepublishOnly": "npm run build && npm run build:types"
  },
  "keywords": [
    "verifiable-credentials",
    "ssi",
    "did",
    "costa-rica",
    "mdl",
    "driving-license",
    "json-ld",
    "w3c",
    "iso-18013-5"
  ],
  "author": "Attestto Open <open@attestto.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Attestto-com/cr-vc-sdk.git"
  },
  "homepage": "https://attestto.org",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "jose": "^6.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
